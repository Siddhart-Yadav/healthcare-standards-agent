# MongoDB Atlas connection string
# Get from: Atlas > Database > Connect > Drivers > Node.js
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/

# Voyage AI API key (generated in Atlas UI under AI Models)
# Starts with "al-" for Atlas-generated keys
# Free tier: 200M tokens
VOYAGE_API_KEY=al-xxxxxxxxxxxxxxxx

# Google Gemini API key (for Path B CLI agent)
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaSy-xxxxxxxxxxxxxxxx

# Anthropic API key (optional, if using Claude instead of Gemini)
# Get from: https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx
